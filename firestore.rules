rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/account/meta)
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/account/meta).data.role == 'admin';
    }

    match /users/{userId}/account/meta {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == 'user';
      allow update, delete: if false;
    }

    match /users/{userId}/{collection}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && collection != 'account';
    }

    match /community/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /communitySubmissions/{foodId} {
      allow create: if request.auth != null
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.moderationStatus == 'pending';
      allow read: if request.auth != null
        && (resource.data.createdByUid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
  }
}
